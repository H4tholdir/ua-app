# UÀ — Environment Variables Template
# Copia in .env.local e compila con i valori reali
# MAI committare .env.local in git

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# === EMAIL (SMTP del laboratorio — configurato per ogni tenant) ===
# Il laboratorio configura il proprio SMTP nelle Preferenze
# Questi sono valori di default per development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dev@example.com
SMTP_PASS=your-app-password

# === FATTURAPA (AdE diretta — nessun intermediario) ===
# MVP: PEC a sdi01@pec.fatturapa.it
# v1.0: SdICoop SOAP endpoint
ADE_SDICOOP_ENDPOINT=https://sdi.fatturapa.gov.it/...
ADE_CLIENT_CERT_PATH=./certs/client.p12
ADE_CLIENT_CERT_PASS=your-cert-password

# === WHATSAPP (wa.me link nativo — nessuna API Meta) ===
# Nessuna chiave API necessaria per wa.me
# Se in futuro si usa Meta Cloud API:
# META_WA_TOKEN=
# META_WA_PHONE_ID=

# === STORAGE ===
# Supabase Storage — configurato via Supabase dashboard
# SUPABASE_STORAGE_URL=auto (derivato da SUPABASE_URL)
